# Keep the real file at /etc/kolkhoz-server.env readable only by root.
DATABASE_URL=postgresql://kolkhoz:replace-me@127.0.0.1:5432/kolkhoz
REDIS_URL=redis://127.0.0.1:6379/0
KOLKHOZ_SUPABASE_URL=https://replace-me.supabase.co
KOLKHOZ_SUPABASE_PUBLISHABLE_KEY=replace-me
# Server-only. Never include this value in the Flutter app or a public config file.
KOLKHOZ_SUPABASE_SECRET_KEY=replace-me
# Supabase user UUIDs allowed to access admin operations and restart control.
KOLKHOZ_ADMIN_USER_IDS=replace-me
# Firebase project ID is not a secret. The service credential is installed
# separately at /etc/kolkhoz-greenfield/firebase-fcm.json with mode 0400.
KOLKHOZ_FIREBASE_PROJECT_ID=replace-me
KOLKHOZ_RUN_NOTIFICATION_WORKER=true
KOLKHOZ_NOTIFICATION_INTERVAL_SECONDS=1
# Better Stack heartbeat URLs are secrets. Set them only after creating the real
# free-plan heartbeats; pings are emitted only after the corresponding job succeeds.
KOLKHOZ_WATCHDOG_HEARTBEAT_URL=replace-me
KOLKHOZ_AI_CANARY_HEARTBEAT_URL=replace-me
KOLKHOZ_AUTH_CACHE_TTL_SECONDS=30
KOLKHOZ_AUTH_CACHE_CAPACITY=100000
KOLKHOZ_HOST=127.0.0.1
KOLKHOZ_PORT=8787
KOLKHOZ_SHARDS=16
KOLKHOZ_DB_POOL_SIZE=16
KOLKHOZ_REALTIME_BUFFER_SIZE=64
KOLKHOZ_REALTIME_MAX_MESSAGE_BYTES=1048576
KOLKHOZ_HTTP_MAX_BODY_BYTES=1048576
KOLKHOZ_LEASE_TTL_SECONDS=15
KOLKHOZ_SESSION_TTL_SECONDS=1800
KOLKHOZ_PRESENCE_TTL_SECONDS=60
KOLKHOZ_LOBBY_COUNTDOWN_SECONDS=30
KOLKHOZ_COMMAND_PARTITION_COUNT=256
# A multi-host deployment must assign each partition to one live worker set.
# Omit only for a single-host process that intentionally consumes all partitions.
# KOLKHOZ_COMMAND_PARTITIONS=0,1,2,3
KOLKHOZ_COMMAND_PARTITION_CAPACITY=100000
KOLKHOZ_COMMAND_MAX_ATTEMPTS=5
KOLKHOZ_COMMAND_VISIBILITY_SECONDS=30
KOLKHOZ_COMMAND_TIMEOUT_SECONDS=10
KOLKHOZ_RUN_COMMAND_WORKER=true
KOLKHOZ_RUN_AUTOMATIC_SCHEDULER=true
KOLKHOZ_RUN_DEADLINE_SCHEDULER=true
KOLKHOZ_RUN_POPULATION_SCHEDULER=true
KOLKHOZ_DEADLINE_INTERVAL=1
KOLKHOZ_DEADLINE_BATCH_SIZE=128
KOLKHOZ_POPULATION_INTERVAL=1
KOLKHOZ_POPULATION_BATCH_SIZE=256
KOLKHOZ_ENFORCE_FULL_GAME=false
KOLKHOZ_APPLE_FULL_GAME_PRODUCT_ID=com.williamtheisen.kolkhoz.fullgame
APPLE_APP_BUNDLE_ID=com.williamtheisen.kolkhoz
# Set these after the App Store app record and Apple PKI certificates exist.
# APPLE_APP_ID=1234567890
# APPLE_ROOT_CERTIFICATE_PATHS=/etc/kolkhoz/apple-root-ca-g3.cer
