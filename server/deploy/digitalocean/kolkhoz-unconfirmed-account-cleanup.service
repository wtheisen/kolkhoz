[Unit]
Description=Delete stale unconfirmed Kolkhoz Supabase accounts
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=kolkhoz-greenfield
Group=kolkhoz-greenfield
WorkingDirectory=/opt/kolkhoz-greenfield
EnvironmentFile=/etc/kolkhoz-greenfield.env
ExecStart=/opt/kolkhoz-greenfield/.venv/bin/python -m server.tools.cleanup_unconfirmed_accounts --older-than-days 7 --delete
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
